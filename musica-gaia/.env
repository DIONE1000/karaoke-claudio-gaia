# Segurança
SECRET_KEY=sua-chave-secreta-aqui
DEBUG=True

# Configurações para o BACKEND dentro do Docker
DB_NAME=musicagaia
DB_USER=admin
DB_PASSWORD=adminpassword
# AQUI ESTÁ O SEGREDO: o host é o nome do serviço no docker-compose
DB_HOST=db
# A porta interna do container MySQL é sempre 3306
DB_PORT=3306

# Configurações para o container do MySQL
DB_ROOT_PASSWORD=root